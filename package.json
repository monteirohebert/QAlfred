{
  "name": "qalfred-e2e-tests",
  "version": "1.0.0",
  "description": "QAlfred - End-to-end test automation with Playwright and Gherkin",
  "main": "src/runner.js",
  "type": "module",
  "scripts": {
    "test": "node src/runner.js",
    "test:feature": "node src/runner.js",
    "test:all": "node src/runner.js --all",
    "test:smoke": "node src/runner.js --tag=smoke",
    "test:regression": "node src/runner.js --tag=regression",
    "test:critical": "node src/runner.js --tag=critical",
    "setup": "playwright install"
  },
  "keywords": [
    "e2e",
    "testing",
    "playwright",
    "gherkin",
    "bdd",
    "automation"
  ],
  "author": "QAlfred Team",
  "license": "MIT",
  "devDependencies": {
    "@cucumber/gherkin": "^28.0.0",
    "@cucumber/message-streams": "^4.1.1",
    "playwright": "^1.48.0"
  },
  "dependencies": {
    "dotenv": "^16.4.5"
  }
}