# QAlfred Environment Configuration
# Copy this file to .env and update with your values

# Application URLs
APP_BASE_URL=https://example.com
APP_LOGIN_URL=https://www.saucedemo.com/
APP_DASHBOARD_URL=https://example.com/dashboard

# ServeRest
SERVEREST_LOGIN_URL=https://front.serverest.dev/login
SERVEREST_API_URL=https://serverest.dev
SERVEREST_ADMIN_EMAIL=admin.qalfred@qa.com
SERVEREST_ADMIN_PASSWORD=Admin@123
SERVEREST_USER_EMAIL=user.qalfred@qa.com
SERVEREST_USER_PASSWORD=User@123

# Test Credentials
TEST_USERNAME=testuser@example.com
TEST_PASSWORD=your_secure_password_here
TEST_USER_VALID_EMAIL=valid@example.com
TEST_USER_INVALID_EMAIL=invalid@example.com

# Playwright Configuration
BROWSER=chromium
HEADLESS=true
SLOW_MO=0
TIMEOUT=30000

# Screenshot Configuration
SCREENSHOT_ON_FAILURE=true
SCREENSHOT_ON_SUCCESS=true
SCREENSHOT_FORMAT=png

# Report Configuration
REPORT_DIR=./reports
REPORT_FORMAT=json
GENERATE_HTML=true

# Execution Configuration
PARALLEL_TESTS=false
MAX_TIMEOUT=60000
RETRY_FAILED=false
RETRY_COUNT=1

# Logging
LOG_LEVEL=info
VERBOSE=false
